DB_HOST=
DB_PASSWORD=
DB_PORT=
DB_USERNAME=
DB_DATABASE=
DB_SSL=
DISPLAY_HALF=true #true or false
MAX_LEVEL=8
NORMAL_PATTERN=true #true or false
CUSTOM_LEVEL= #1a,2b,3c,4d,5d,6c,7b,8a
MODEL_BANTAL=false #true or false
BUTTON_MODE=false #true or false - Enable button-triggered image display mode
HIDE_CAMERA=false #true or false - Hide camera section (show only timer and design)

# Performance Optimization Settings
YOLO_SKIP_FRAMES=2 # Process YOLO every N+1 frames (0=every frame, 2=every 3rd frame)
MEDIAPIPE_SKIP_FRAMES=2 # Process MediaPipe every N+1 frames
DEBUG_MODE=false # Set to 'true' to see detailed performance metrics

# Higher skip values = better FPS but slower detection response
# Recommended for PC: YOLO=2-3, MEDIAPIPE=2-3
# Recommended for Jetson Xavier AGX: YOLO=1-2, MEDIAPIPE=1-2
# If hand detection not needed, set MEDIAPIPE_SKIP_FRAMES=10 or higher